<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<HBox xmlns:fx="http://javafx.com/fxml"
  fx:id="chatRoot"
      fx:controller="com.chitchat.client.controller.ChatController"
      styleClass="chat-root">

  <!-- Sidebar -->
  <VBox styleClass="sidebar" prefWidth="280" minWidth="220">

    <!-- Header Line 1: Brand -->
    <VBox styleClass="sidebar-header" alignment="CENTER" spacing="12">
      <padding><Insets top="16" right="10" bottom="0" left="10"/></padding>
      <Label text="ChitChat" styleClass="brand-small"/>
    </VBox>

    <!-- Header Line 2: Action Buttons -->
    <HBox alignment="CENTER" spacing="8">
      <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
      <Button text="⚙" onAction="#handlePreferences" styleClass="btn-header-icon">
        <tooltip><Tooltip text="Preferences"/></tooltip>
      </Button>
      <Button text="⛔" onAction="#handleBlockedUsers" styleClass="btn-header-icon">
        <tooltip><Tooltip text="Blocked Users"/></tooltip>
      </Button>
      <Button text="👤" onAction="#handleProfile" styleClass="btn-header-icon">
        <tooltip><Tooltip text="Profile"/></tooltip>
      </Button>
      <Button text="✕" onAction="#handleLogout" styleClass="btn-header-icon">
        <tooltip><Tooltip text="Logout"/></tooltip>
      </Button>
    </HBox>

    <!-- Logged-in user info -->
    <Label fx:id="userInfoLabel" styleClass="user-info-label" wrapText="true"/>

    <!-- Header Line 3: Friends section header -->
    <HBox alignment="CENTER_LEFT" spacing="6">
      <padding><Insets top="10" right="10" bottom="4" left="10"/></padding>
      <Label text="FRIENDS" styleClass="section-title" HBox.hgrow="ALWAYS"/>
      <Button text="Req" styleClass="btn-add-friend" onAction="#handleFriendRequests"/>
      <Button text="Edit" styleClass="btn-add-friend" onAction="#handleAddFriend"/>
    </HBox>

    <!-- Friends list -->
    <ListView fx:id="userListView" styleClass="user-list" VBox.vgrow="ALWAYS"/>

    <!-- Group Rooms section -->
    <HBox alignment="CENTER_LEFT" spacing="6">
      <padding><Insets top="8" right="10" bottom="4" left="10"/></padding>
      <Label text="GROUP ROOMS" styleClass="section-title" HBox.hgrow="ALWAYS"/>
      <Button text="+ New" styleClass="btn-add-friend" onAction="#handleCreateRoom"/>
    </HBox>

    <!-- Rooms list -->
    <ListView fx:id="roomListView" styleClass="user-list" prefHeight="120"/>

  </VBox>

  <!-- Main Chat -->
  <VBox HBox.hgrow="ALWAYS" styleClass="chat-main">

    <!-- Chat header -->
    <HBox styleClass="chat-header" alignment="CENTER_LEFT" spacing="8">
      <Label fx:id="chatHeaderLabel" text="Public Chat" styleClass="chat-header-title" HBox.hgrow="ALWAYS"/>
      <Region HBox.hgrow="ALWAYS"/>
      <Button fx:id="callVoiceButton" text="📞" styleClass="btn-call" onAction="#handleVoiceCall" visible="false" managed="false"/>
      <Button fx:id="callVideoButton" text="🎥" styleClass="btn-call" onAction="#handleVideoCall" visible="false" managed="false"/>
      <Button fx:id="leaveRoomButton" text="Leave" styleClass="btn-room-leave" onAction="#handleLeaveRoom" visible="false" managed="false"/>
      <Button fx:id="endCallButton" text="End" styleClass="btn-call-end" onAction="#handleEndCall" visible="false" managed="false"/>
    </HBox>

    <!-- Messages -->
    <ScrollPane fx:id="messagesScroll" VBox.vgrow="ALWAYS" fitToWidth="true"
                styleClass="messages-scroll" hbarPolicy="NEVER">
      <VBox fx:id="messagesBox" styleClass="messages-box" spacing="4">
        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
      </VBox>
    </ScrollPane>

    <Label fx:id="typingIndicatorLabel" styleClass="typing-indicator" visible="false" managed="false"/>

    <!-- Input bar -->
    <HBox styleClass="message-bar" spacing="10" alignment="CENTER">
      <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>
      <TextField fx:id="messageInput" promptText="Type a message..."
                 styleClass="msg-input" HBox.hgrow="ALWAYS"
                 onAction="#handleSend"/>
      <Button fx:id="attachImageButton" text="🖼" onAction="#handleSendImage" styleClass="btn-attach"/>
      <Button text="Send" onAction="#handleSend" styleClass="btn-send"/>
    </HBox>

  </VBox>

</HBox>
